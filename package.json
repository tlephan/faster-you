{
  "name": "faster-you",
  "version": "1.0.1",
  "description": "A fast, minimal task manager built with NeutralinoJS",
  "type": "module",
  "scripts": {
    "dev:web": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "neu:update": "npx neu update",
    "neu:run": "npx neu run",
    "neu:build": "npm run build && npx neu build --embed-resources --release",
    "dev": "concurrently \"vite --port 3000\" \"wait-on http://localhost:3000 && npx neu run -- --url=http://localhost:3000\""
  },
  "keywords": [
    "todo",
    "task-manager",
    "neutralinojs",
    "react"
  ],
  "author": "tlephan",
  "license": "MIT",
  "devDependencies": {
    "@neutralinojs/neu": "^11.7.0",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.1.4",
    "concurrently": "^9.1.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.7.0",
    "vite": "^7.3.1",
    "wait-on": "^9.0.4"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@neutralinojs/lib": "^5.4.0",
    "@tanstack/react-query": "^5.62.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sql.js": "^1.11.0",
    "tailwind-merge": "^3.5.0",
    "uuid": "^13.0.0"
  }
}
